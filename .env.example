# Required. Generate a long random value; never commit the real key.
MIMIR_API_KEY=replace-with-a-random-secret

# The directory must already exist.
MIMIR_ROOT_DIR=/home/mimir/mimir
MIMIR_HOST=127.0.0.1
MIMIR_PORT=3031
MIMIR_ALLOWED_HOSTS=files.example.com

# Stable identity reported to Heimdall. Set these for non-local deployments.
MIMIR_INSTANCE_ID=archive-primary
MIMIR_DEPLOY_HOST=files-01

# Leave unset unless Mímir is reachable only through the named proxy path.
# MIMIR_TRUST_PROXY=loopback

# Optional share links. Generate a separate random value.
# MIMIR_SHARE_SECRET=replace-with-a-different-random-secret
# MIMIR_BASE_URL=https://files.example.com

# Optional Heimdall integration.
# HEIMDALL_HUB_URL=https://monitoring.example.com/api/panels
# HEIMDALL_FLEET_TOKEN=replace-with-a-random-secret
