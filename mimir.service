[Unit]
Description=Mímir File Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=magnus
WorkingDirectory=/home/magnus/mimir-server
ExecStart=/usr/bin/node dist/index.js
Restart=always
RestartSec=5
EnvironmentFile=/home/magnus/mimir-server/.env

# Sandboxing
ProtectSystem=strict
ReadWritePaths=/home/magnus/mimir-server
ReadOnlyPaths=/home/magnus/mimir
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
